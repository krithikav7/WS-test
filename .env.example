# Copy this file to ".env" and fill in your real values.
# Never commit the real .env file.

# Your unique API key from Writesonic (AI Bot Analytics > Custom provider > Continue)
WRITESONIC_API_KEY=9a6e3ebb-664f-4903-8d2e-0f7b1c55cd4b

# Writesonic ingestion endpoint (leave as-is unless Writesonic tells you otherwise)
WRITESONIC_INGEST_URL=https://ingestion.writesonic.com/api/v1/analytics/ingest

# Port your test site runs on
PORT=3000

# Set to "true" to print each forwarded payload to the console (handy while testing)
DEBUG_FORWARD=true
